-- ============================================================
--  COMPATIBILITY SHIMS
--  Provides safe fallbacks for functions missing in low-UNC
--  executors (Arceus X, Codex, etc.)
-- ============================================================
if not getgenv then
	getgenv = function() return getfenv(0) end
end

if not getnilinstances then
	getnilinstances = function() return {} end
end

if not newcclosure then
	newcclosure = function(f) return f end
end

if not islclosure then
	islclosure = function(f)
		local ok, res = pcall(function() return not iscclosure(f) end)
		return ok and res or false
	end
end

if not iscclosure then
	iscclosure = function() return false end
end

if not getrawmetatable then
	getrawmetatable = function(o)
		local mt = getmetatable(o)
		return mt
	end
end

if not setreadonly then
	setreadonly = function() end
end

if not hookfunction then
	-- Minimal hookfunction shim using debug if available
	hookfunction = function(func, hook)
		local old = func
		if debug and debug.sethook then
			-- can't truly hook, just return original
		end
		return old
	end
end

if not hookmetamethod then
	hookmetamethod = nil  -- will use __namecall path instead
end

if not getnamecallmethod then
	getnamecallmethod = function() return "" end
end

if not setnamecallmethod then
	setnamecallmethod = function() end
end

if not getcallingscript then
	getcallingscript = function() return nil end
end

if not identifyexecutor then
	if getexecutorname then
		identifyexecutor = getexecutorname
	else
		identifyexecutor = function() return "Unknown" end
	end
end

if not getexecutorname then
	getexecutorname = identifyexecutor
end

