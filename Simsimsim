if not _G.SimpleSpyExecuted then
	local succeeded, err = pcall(function()
		if not RunService:IsClient() then error("SimpleSpy cannot run on the server!") end
		-- Soft check: warn but continue with shims applied at top of script
		do
			local missing = {}
			if not hookfunction then table.insert(missing, "hookfunction") end
			if not getrawmetatable then table.insert(missing, "getrawmetatable") end
			if not setreadonly then table.insert(missing, "setreadonly") end
			if #missing > 0 then
				warn("[SimpleSpy] Missing functions (shims applied): " .. table.concat(missing, ", "))
			end
		end
		_G.SimpleSpyShutdown = shutdown
		pcall(function() ContentProvider:PreloadAsync({ "rbxassetid://6065821980", "rbxassetid://6065774948", "rbxassetid://6065821086", "rbxassetid://6065821596", ImageLabel, ImageLabel_2, ImageLabel_3 }) end)
		onToggleButtonClick()
		RemoteTemplate.Parent = nil
		FunctionTemplate.Parent = nil
		codebox = Highlight.new(CodeBox)
		codebox:setRaw("")
		pcall(function()
			getgenv().SimpleSpy = SimpleSpy
			getgenv().getNil = function(name, class)
				for _, v in pairs(getnilinstances()) do if v.ClassName == class and v.Name == name then return v end end
			end
		end)
		TextLabel:GetPropertyChangedSignal("Text"):Connect(scaleToolTip)
		MinimizeButton.MouseButton1Click:Connect(toggleMinimize)
		MaximizeButton.MouseButton1Click:Connect(toggleSideTray)
		Simple.MouseButton1Click:Connect(onToggleButtonClick)
		CloseButton.MouseEnter:Connect(onXButtonHover)
		CloseButton.MouseLeave:Connect(onXButtonUnhover)
		Simple.MouseEnter:Connect(onToggleButtonHover)
		Simple.MouseLeave:Connect(onToggleButtonUnhover)
		CloseButton.MouseButton1Click:Connect(shutdown)
		table.insert(connections, UserInputService.InputBegan:Connect(backgroundUserInput))
		connectResize()
		SimpleSpy2.Enabled = true
		coroutine.wrap(function() wait(1); onToggleButtonUnhover() end)()
		schedulerconnect = RunService.Heartbeat:Connect(taskscheduler)
		pcall(syn.protect_gui, SimpleSpy2)
		bringBackOnResize()
		SimpleSpy2.Parent = getSafeGuiParent()

		-- Detect executor name and show Roblox notification
		coroutine.wrap(function()
			wait(1)
			local executorName = "Unknown"
			if identifyexecutor then
				pcall(function() executorName = identifyexecutor() end)
			elseif KRNL_LOADED then
				executorName = "Krnl"
			elseif syn then
				executorName = "Synapse X"
			elseif rconsoleprint then
				executorName = "ScriptWare"
			elseif getexecutorname then
				pcall(function() executorName = getexecutorname() end)
			end
			pcall(function()
				game:GetService("StarterGui"):SetCore("SendNotification", {
					Title = "SimpleSpy Modded By Fenzoxy",
					Text = "Loaded! Executor: " .. tostring(executorName),
					Duration = 5,
				})
			end)
		end)()

		-- Parent the Open Button GUI
		pcall(syn.protect_gui, OpenButtonGui)
		OpenButtonGui.Parent = getSafeGuiParent()

		-- Open Button: manual drag logic
		do
			local dragging = false
			local dragMoved = false
			local dragStartPos
			local frameStartPos

			OBBtn.InputBegan:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = true
					dragMoved = false
					dragStartPos = input.Position
					frameStartPos = OBFrame.AbsolutePosition
				end
			end)

			OBBtn.InputChanged:Connect(function(input)
				if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
					local delta = input.Position - dragStartPos
					if delta.Magnitude > 4 then
						dragMoved = true
					end
					if dragMoved then
						local newX = frameStartPos.X + delta.X
						local newY = frameStartPos.Y + delta.Y
						local vp = workspace.CurrentCamera.ViewportSize
						newX = math.clamp(newX, 0, vp.X - OBFrame.AbsoluteSize.X)
						newY = math.clamp(newY, 0, vp.Y - OBFrame.AbsoluteSize.Y)
						OBFrame.Position = UDim2.fromOffset(newX, newY)
					end
				end
			end)

			OBBtn.InputEnded:Connect(function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
					dragging = false
				end
			end)

			-- Toggle only fires if user did NOT drag
			OBBtn.MouseButton1Click:Connect(function()
				if dragMoved then return end
				Background.Visible = not Background.Visible
				if Background.Visible then
					OBLabel.TextColor3 = Color3.fromRGB(100, 255, 160)
					OBStroke.Color = Color3.fromRGB(100, 255, 160)
				else
					OBLabel.TextColor3 = Color3.fromRGB(120, 170, 255)
					OBStroke.Color = Color3.fromRGB(80, 130, 255)
				end
			end)
		end
		OBBtn.MouseEnter:Connect(function()
			TweenService:Create(OBFrame, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(55, 54, 62) }):Play()
		end)
		OBBtn.MouseLeave:Connect(function()
			TweenService:Create(OBFrame, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(37, 36, 42) }):Play()
		end)

		-- Discord button logic
		DiscordButton.MouseButton1Click:Connect(function()
			setclipboard("https://discord.gg/bZyMGmjqUe")
			TextLabel.Text = "Discord link copied!"
		end)
		DiscordButton.MouseEnter:Connect(function()
			TweenService:Create(DiscordButton, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(110, 120, 255) }):Play()
		end)
		DiscordButton.MouseLeave:Connect(function()
			TweenService:Create(DiscordButton, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(88, 101, 242) }):Play()
		end)

		-- For Delta button
		DeltaButton.MouseButton1Click:Connect(function()
			shutdown()
			pcall(function()
				loadstring(game:HttpGet("https://raw.githubusercontent.com/Dyno67-art/Beta-Spy/refs/heads/main/Testing"))()
			end)
		end)
		DeltaButton.MouseEnter:Connect(function()
			TweenService:Create(DeltaButton, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(130, 235, 150) }):Play()
		end)
		DeltaButton.MouseLeave:Connect(function()
			TweenService:Create(DeltaButton, TweenInfo.new(0.15), { BackgroundColor3 = Color3.fromRGB(100, 210, 120) }):Play()
		end)

		_G.SimpleSpyExecuted = true
		if not Players.LocalPlayer then Players:GetPropertyChangedSignal("LocalPlayer"):Wait() end
		Mouse = Players.LocalPlayer:GetMouse()
		oldIcon = Mouse.Icon
		table.insert(connections, Mouse.Move:Connect(mouseMoved))
	end)
	if not succeeded then
		warn("A fatal error has occured, SimpleSpy was unable to launch properly.\nPlease DM this error message to @exx#9394:\n\n" .. tostring(err))
		SimpleSpy2:Destroy()
		pcall(function() OpenButtonGui:Destroy() end)
		hookfunction(remoteEvent.FireServer, originalEvent)
		hookfunction(remoteFunction.InvokeServer, originalFunction)
		if hookmetamethod then if original then hookmetamethod(game, "__namecall", original) end
		else setreadonly(gm, false); gm.__namecall = original; setreadonly(gm, true) end
		return
	end
else
	SimpleSpy2:Destroy()
	return
end

