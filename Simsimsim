	elseif y + Background.AbsolutePosition.Y > screenSize.Y then
		if screenSize.X - Background.AbsolutePosition.Y >= 310 then y = screenSize.Y - Background.AbsolutePosition.Y else y = 310 end
	end
	Background.Size = UDim2.fromOffset(x, y)
end

