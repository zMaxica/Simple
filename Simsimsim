--- Filter: show only remotes whose name contains a keyword (stored in a TextBox-style prompt via codebox)
newButton("Filter Name", function()
	return "Type a keyword in the codebox first, then click to filter log list by remote name (case-insensitive). Click again with empty codebox to clear filter."
end, function()
	local keyword = codebox:getString():lower():gsub("%s+", "")
	if keyword == "" then
		-- Clear filter: show all logs
		for _, v in pairs(logs) do
			if v.Log and v.Log.Parent then
				v.Log.Visible = true
			end
		end
		TextLabel.Text = "Filter cleared, all logs shown."
	else
		local count = 0
		for _, v in pairs(logs) do
			if v.Log and v.Log.Parent then
				local match = v.Name:lower():find(keyword, 1, true)
				v.Log.Visible = match ~= nil
				if match then count = count + 1 end
			end
		end
		TextLabel.Text = "Filter '" .. keyword .. "': " .. count .. " match(es)"
	end
	updateRemoteCanvas()
end)

